# Backend Environment Variables

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required: Random secret for session signing (generate a long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Required: Initial admin credentials for first-run setup
# These seed the admin account the first time the database is empty.
# Change them after first login via the admin settings panel.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Required: Port the server listens on (set automatically in Replit workflows)
PORT=8080

# Required for production: Frontend origin(s) for CORS
# Comma-separated for multiple, e.g. "https://your-app.replit.app"
FRONTEND_URL=https://your-frontend.replit.app

# Optional
NODE_ENV=production
