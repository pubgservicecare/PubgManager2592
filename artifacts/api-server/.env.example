# Backend Environment Variables (Render)

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required: Random secret for session signing (generate a long random string)
SESSION_SECRET=change-me-to-a-long-random-string

# Required: Port the server listens on (Render sets this automatically)
PORT=8080

# Required for production: Frontend origin(s) for CORS
# Comma-separated for multiple, e.g. "https://your-app.vercel.app,https://www.your-domain.com"
FRONTEND_URL=https://your-frontend.vercel.app

# Optional
NODE_ENV=production
