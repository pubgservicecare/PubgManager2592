<?xml version="1.0" encoding="UTF-8"?>
<!--
  NOTE: This static file is a fallback for local development only.
  In production, /sitemap.xml is served dynamically by Express
  and includes all active public account pages from the database.
-->
<urlset
  xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9
    http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">

  <!-- Marketplace homepage -->
  <url>
    <loc>https://www.codexstocks.org/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- All accounts hub -->
  <url>
    <loc>https://www.codexstocks.org/accounts</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- FAQ — long-tail SEO, answers buyer questions -->
  <url>
    <loc>https://www.codexstocks.org/faq</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>

  <!--
    /signup is intentionally excluded — it is a form page with no SEO value
    and is blocked in robots.txt.

    Individual account pages (/account/:slug) are injected dynamically
    by the Express server from the database.
  -->

</urlset>
